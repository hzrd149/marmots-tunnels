# Example configuration for the tunnels server.
#
# Copy to `.env` and fill in what you need — every variable is optional and
# falls back to the default shown. Load it with `node --env-file=.env dist/index.js`
# or `docker run --env-file .env ...`.

# 32-byte hex Nostr secret key for the server's MLS identity.
# Default: a key is generated on first run and saved to $TUNNELS_DATA/identity.key.
# When set, this value is authoritative and is NOT written to disk.
# TUNNELS_SECRET=

# NIP-65 (kind 10002) outbox relays: profile, relay lists, KeyPackage.
# Comma-separated. Falls back to TUNNELS_RELAYS, then the built-in defaults.
# TUNNELS_OUTBOX_RELAYS="wss://relay.damus.io,wss://nos.lol"

# Welcome-inbox (kind 10050) relays: where group invites are watched.
# Comma-separated. Falls back to TUNNELS_RELAYS, then the built-in defaults.
# TUNNELS_INBOX_RELAYS="wss://relay.damus.io,wss://nos.lol"

# Shared fallback for both inbox and outbox when the specific var above is unset.
# Comma-separated.
# Built-in defaults: wss://relay.us.whitenoise.chat,wss://relay.damus.io,wss://nos.lol
# TUNNELS_RELAYS="wss://relay.us.whitenoise.chat,wss://relay.damus.io,wss://nos.lol"

# Directory for the SQLite database (state.db) and the generated identity key.
# Default: ./data  (the Docker image sets this to /data)
# TUNNELS_DATA=./data

# Inactivity TTL: when > 0, purge groups with no kind-445 activity for this many
# hours. Default: unset — groups are retained forever.
# TUNNELS_GROUP_TTL_HOURS=

# Access gate: comma-separated list of npubs allowed to view the app. When set,
# the UI is gated behind a Nostr login (NIP-WT) restricted to these keys. Unset
# or empty (the default) means the site is fully public. Raw 64-char hex pubkeys
# are also accepted.
# NOSTR_WHITELIST="npub1...,npub1..."

# Login session length in hours (only relevant when NOSTR_WHITELIST is set).
# Default: 24
# NOSTR_SESSION_HOURS=24

# HTTP port for the web UI. Default: 3000
# PORT=3000
